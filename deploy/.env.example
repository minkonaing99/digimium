DIGIMIUM_DB_HOST=
DIGIMIUM_DB_PORT=
DIGIMIUM_DB_NAME=
DIGIMIUM_DB_USER=
DIGIMIUM_DB_PASS=

DIGIMIUM_SESSION_NAME=ERASESSID
DIGIMIUM_SESSION_SAMESITE=Lax
DIGIMIUM_SESSION_SECURE=true
DIGIMIUM_SESSION_MAX_LIFETIME=28800

DIGIMIUM_REMEMBER_SECRET=

# Leave unset if the storefront is deployed as a sibling directory named `digimium.store`.
# Example override:
# DIGIMIUM_STOREFRONT_PATH=/var/www/digimium.store

# Optional public URL used by the admin product showcase to preview storefront images.
# Example:
# DIGIMIUM_STOREFRONT_PUBLIC_URL=https://digimium.store

APP_ENV=production
APP_DEBUG=false
